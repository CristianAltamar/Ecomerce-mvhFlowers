# === Servidor ===
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# === Base de datos PostgreSQL ===
DATABASE_URL=postgresql://mvh:mvh_dev_password@localhost:5432/mvh_store?schema=public

# === Redis ===
REDIS_URL=redis://:mvh_redis_dev@localhost:6379

# === JWT ===
# IMPORTANTE: en producción generar valores aleatorios largos con:
# openssl rand -base64 64
JWT_ACCESS_SECRET=dev_access_secret_change_in_production_minimum_32_chars
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production_minimum_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# === Seguridad ===
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# === Cloudinary (Entrega 3) ===
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# === Bold — Botón de pagos ===
# BOLD_API_KEY     = Llave de IDENTIDAD (pública). Va en el botón del front (data-api-key).
# BOLD_SECRET_KEY  = Llave SECRETA. Firma de integridad del botón + verificación del webhook.
BOLD_API_KEY=
BOLD_SECRET_KEY=
# Opcional: override de la llave para verificar el webhook (por defecto usa BOLD_SECRET_KEY)
BOLD_WEBHOOK_SECRET=
BOLD_ENVIRONMENT=sandbox
# Solo dev/sandbox: 'true' omite la verificación de firma del webhook (NUNCA en producción)
BOLD_WEBHOOK_SKIP_VERIFY=false

# === Logs ===
LOG_LEVEL=debug

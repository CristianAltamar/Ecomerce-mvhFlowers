# ============================================================
#  MVH FLORES — Variables de entorno para PRODUCCIÓN
#  Copiar como .env en el servidor VPS (apps/api/.env)
#  Las variables NEXT_PUBLIC_* se configuran en Vercel
# ============================================================

# === Servidor ===
NODE_ENV=production
PORT=4000
API_BASE_URL=https://api.mvhflores.co
CORS_ORIGINS=https://mvhflores.co,https://www.mvhflores.co

# === PostgreSQL — Neon ===
# Obtener desde: console.neon.tech → Connection string
DATABASE_URL=postgresql://USER:PASS@ep-XXXXX.us-east-2.aws.neon.tech/mvh_store?sslmode=require&pgbouncer=true&connect_timeout=15

# === Redis — Upstash ===
# Obtener desde: console.upstash.com → Redis → Connect → ioredis
# Usar la URL con TLS (rediss://)
REDIS_URL=rediss://:PASSWORD@ENDPOINT.upstash.io:6380

# === JWT — Generar con: openssl rand -base64 64 ===
JWT_ACCESS_SECRET=CAMBIAR_POR_SECRETO_ALEATORIO_64_CHARS
JWT_REFRESH_SECRET=CAMBIAR_POR_SECRETO_ALEATORIO_64_CHARS_DIFERENTE
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# === Seguridad ===
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# === Cloudinary — Almacenamiento de imágenes ===
# Obtener desde: cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=mvhflores
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# === Bold — Pagos ===
# Obtener desde: panel.bold.co → Desarrolladores → Credenciales
BOLD_API_KEY=
BOLD_SECRET_KEY=
BOLD_WEBHOOK_SECRET=
BOLD_ENVIRONMENT=production

# === SMTP — Emails transaccionales ===
# Ejemplo con SendGrid:
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=SG.XXXXXXXXXXXX
SMTP_FROM=MVH Flores <hola@mvhflores.co>

# === Logs ===
LOG_LEVEL=info
